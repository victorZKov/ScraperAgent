# PostgreSQL
POSTGRES_USER=scraperagent
POSTGRES_PASSWORD=change-me
POSTGRES_DB=scraperagent

# Connection string (uses Docker service name "postgres")
ConnectionStrings__configdb=Host=postgres;Port=5432;Database=scraperagent;Username=scraperagent;Password=change-me

# Azure OpenAI
AzureOpenAI__Endpoint=https://your-endpoint.openai.azure.com/
AzureOpenAI__ApiKey=your-key
AzureOpenAI__DeploymentName=gpt-4o

# SMTP (Scaleway)
Email__Smtp__Username=your-smtp-user
Email__Smtp__Password=your-smtp-pass

# Finnhub
Finnhub__ApiKey=your-finnhub-key

# Mollie payments
Mollie__ApiKey=live_xxxxx
Mollie__WebhookBaseUrl=https://api.scraperagent.victorz.cloud
Mollie__RedirectBaseUrl=https://your-vercel-domain.vercel.app

# Misc
TweetSource=live
ReportRecipients=email@example.com
SearXNG__BaseUrl=http://searxng:8080
ASPNETCORE_ENVIRONMENT=Production

# Docker image (set by CI/CD)
GITHUB_REPOSITORY=yourusername/scraperagent
IMAGE_TAG=latest
