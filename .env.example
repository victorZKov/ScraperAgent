# Managed PostgreSQL (Scaleway)
ConnectionStrings__configdb=Host=<DB_PRIVATE_IP>;Port=<DB_PORT>;Database=scraperagent;Username=scraperagent;Password=<DB_PASSWORD>;SSL Mode=Require;Trust Server Certificate=true

# Azure OpenAI
AzureOpenAI__Endpoint=https://your-endpoint.openai.azure.com/
AzureOpenAI__ApiKey=your-key
AzureOpenAI__DeploymentName=gpt-4o

# SMTP (Scaleway)
Email__Smtp__Username=your-smtp-user
Email__Smtp__Password=your-smtp-pass

# Finnhub
Finnhub__ApiKey=your-finnhub-key

# Mollie payments
Mollie__ApiKey=live_xxxxx
Mollie__WebhookBaseUrl=https://api.scraperagent.eu
Mollie__RedirectBaseUrl=https://scraperagent.eu

# Misc
TweetSource=live
ReportRecipients=email@example.com
SearXNG__BaseUrl=http://searxng:8080
ASPNETCORE_ENVIRONMENT=Production

# Docker image (set by CI/CD)
GITHUB_REPOSITORY_LOWER=yourusername/scraperagent
IMAGE_TAG=latest
