# =============================================================
#  ScraperAgent - Home Deployment Environment Variables
#
#  Copy this file to .env and fill in the real values.
#  NEVER commit the .env file to git!
# =============================================================

# --- PostgreSQL (local, in Docker) ---
DB_PASSWORD=<DB_PASSWORD>

# --- AI Models (seeded into DB on first run) ---
AzureOpenAI__Endpoint=<AZURE_OPENAI_ENDPOINT>
AzureOpenAI__ApiKey=<AZURE_OPENAI_KEY>
AzureOpenAI__DeploymentName=gpt-4o
ScalewayAI__ApiKey=<SCALEWAY_AI_KEY>

# --- SMTP (Scaleway Transactional Email) ---
Email__Smtp__Username=<SMTP_USERNAME>
Email__Smtp__Password=<SMTP_PASSWORD>

# --- Finnhub (market data) ---
Finnhub__ApiKey=<FINNHUB_KEY>

# --- Mollie Payments ---
Mollie__ApiKey=<MOLLIE_LIVE_KEY>
Mollie__WebhookBaseUrl=https://api.scraperagent.eu
Mollie__RedirectBaseUrl=https://scraperagent.victorz.cloud

# --- Twitter Scraping ---
TweetSource=live

# --- Email recipients (comma-separated) ---
ReportRecipients=<YOUR_EMAIL>

# --- Cloudflare Tunnel Token ---
# Get this from Zero Trust dashboard -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=<TUNNEL_TOKEN>

# --- Misc ---
ASPNETCORE_ENVIRONMENT=Production
