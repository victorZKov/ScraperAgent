# =============================================================
#  ScraperAgent — Home Deployment Environment Variables
#
#  Copy this file to .env and fill in the real values.
#  NEVER commit the .env file to git!
# =============================================================

# --- PostgreSQL (Scaleway Managed — use PUBLIC endpoint) ---
ConnectionStrings__configdb=Host=<DB_PUBLIC_IP>;Port=<DB_PORT>;Database=scraperagent;Username=scraperagent;Password=<DB_PASSWORD>;SSL Mode=Require;Trust Server Certificate=true

# --- AI (configured in DB, but Azure fallback in appsettings) ---
AzureOpenAI__Endpoint=https://sw-g-kov-genai-openai01.openai.azure.com/
AzureOpenAI__ApiKey=<AZURE_OPENAI_KEY>
AzureOpenAI__DeploymentName=gpt-4o

# --- SMTP (Scaleway Transactional Email) ---
Email__Smtp__Username=<SMTP_USERNAME>
Email__Smtp__Password=<SMTP_PASSWORD>

# --- Finnhub (market data) ---
Finnhub__ApiKey=<FINNHUB_KEY>

# --- Mollie Payments ---
Mollie__ApiKey=<MOLLIE_LIVE_KEY>
Mollie__WebhookBaseUrl=https://api.scraperagent.eu
Mollie__RedirectBaseUrl=https://scraperagent.victorz.cloud

# --- Twitter Scraping ---
TweetSource=live

# --- Email recipients (comma-separated) ---
ReportRecipients=<YOUR_EMAIL>

# --- Cloudflare Tunnel Token ---
# Get this from: cloudflared tunnel create scraperagent
# Then: cloudflared tunnel token scraperagent
CLOUDFLARE_TUNNEL_TOKEN=<TUNNEL_TOKEN>

# --- Misc ---
ASPNETCORE_ENVIRONMENT=Production
