    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-npm.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-git-push.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-claude-attribution.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-terraform-apply.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-destructive-az.sh"
          },
          {
